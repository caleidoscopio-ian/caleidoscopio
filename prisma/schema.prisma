  INATIVO
  SUSPENSO
  EM_NEGOCIACAO
}

enum TipoConvenio {
  PLANO_SAUDE
  CONVENIO_EMPRESA
  CONVENIO_ESCOLAR
  CONVENIO_PUBLICO
  PARTICULAR_DESCONTO
  OUTROS
}

