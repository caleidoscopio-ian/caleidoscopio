  VALOR_FIXO    // Valor fixo por atendimento
  VALOR_HORA    // Valor por hora de atendimento
}

enum StatusPacote {
  ATIVO
  INATIVO
  ESGOTADO
}

enum TipoPacote {
  SESSOES_ILIMITADAS
  COMBO_MISTO
  AVALIACAO_COMPLETA
  OUTROS
}

model Convenio {
  id                    String             @id @default(uuid())
  tenantId              String             // Referência ao tenant do Sistema 1 (não FK)

  // Dados Básicos
  razao_social          String
  nome_fantasia         String?
  cnpj                  String
  registro_ans          String?            // Registro na ANS (Agência Nacional de Saúde Suplementar)
  tipo                  TipoConvenio
  status                StatusConvenio     @default(EM_NEGOCIACAO)

  // Contato
  telefone              String?
  email                 String?
  site                  String?
  endereco              String?            @db.Text
  contato_nome          String?            // Nome do contato principal
  contato_telefone      String?
  contato_email         String?

  // Configurações Financeiras
  prazo_pagamento_dias  Int?               // Prazo padrão de pagamento em dias
  dia_fechamento        Int?               // Dia do mês para fechamento do faturamento
  dia_entrega_guias     Int?               // Dia limite para entrega de guias
  percentual_repasse    Decimal?           @db.Decimal(5, 2) // Percentual de repasse

  // Parâmetros TISS
  versao_tiss           String?            // Versão do padrão TISS (ex: "4.01.00")
  tipo_guia_padrao      TipoGuiaTISS?      // Tipo de guia mais usado
  regime_atendimento    RegimeAtendimento? @default(AMBULATORIAL)
  carater_atendimento   CaraterAtendimento? @default(ELETIVO)
  codigo_operadora      String?            // Código da operadora na ANS
  codigo_prestador      String?            // Código do prestador junto ao convênio
  numero_lote_padrao    String?            // Prefixo de lote para envio

  // Datas
  data_inicio_contrato  DateTime?
  data_fim_contrato     DateTime?
  data_ultimo_reajuste  DateTime?

  // Observações
  observacoes           String?            @db.Text

  // Controle
  ativo                 Boolean            @default(true)
  createdAt             DateTime           @default(now())
  updatedAt             DateTime           @default(now()) @updatedAt

  // Relações
  tabelas               ConvenioTabela[]
  anexos                ConvenioAnexo[]
  historicos            ConvenioHistorico[]
  pacientes             paciente[]
  regrasRepasse         RegraRepasse[]
  pacotes               Pacote[]

  @@unique([tenantId, cnpj])
  @@index([tenantId])
  @@index([tenantId, status])
  @@map("convenios")
}

model ConvenioTabela {
  id                  String          @id @default(uuid())
  convenioId          String
  tenantId            String          // Denormalizado para queries multi-tenant
  procedimentoId      String?         // FK opcional para Procedimento

  // Identificação do procedimento
  codigo_procedimento String          // Código TUSS/TISS do procedimento
  nome_procedimento   String          // Nome do procedimento
  codigo_tiss         String?         // Código TISS específico

  // Valores
  valor_convenio      Decimal         @db.Decimal(10, 2) // Valor pago pelo convênio
  valor_particular    Decimal?        @db.Decimal(10, 2) // Valor particular de referência
  valor_co_participacao Decimal?      @db.Decimal(10, 2) // Co-participação do paciente

  // Parâmetros TISS do procedimento (override)
  tipo_guia           TipoGuiaTISS?   // Tipo de guia para este procedimento específico
  tipo_tabela         String?         // "22" (TUSS), "00" (própria), etc.
  grau_participacao   String?         // "00" (cirurgião), "01" (auxiliar), etc.

  // Vigência
  vigencia_inicio     DateTime?
  vigencia_fim        DateTime?

  // Controle
  ativo               Boolean         @default(true)
  createdAt           DateTime        @default(now())
  updatedAt           DateTime        @default(now()) @updatedAt

  convenio            Convenio        @relation(fields: [convenioId], references: [id], onDelete: Cascade)
  procedimento        Procedimento?   @relation(fields: [procedimentoId], references: [id], onDelete: SetNull)

  @@unique([convenioId, codigo_procedimento])
  @@index([tenantId])
  @@map("convenio_tabelas")
}

model ConvenioAnexo {
  id             String            @id @default(uuid())
  convenioId     String
  tenantId       String            // Denormalizado para queries multi-tenant
  tipo           TipoConvenioAnexo
  titulo         String
  descricao      String?           @db.Text
  arquivo_url    String            // URL do arquivo (Vercel Blob)
  arquivo_nome   String            // Nome original do arquivo
  arquivo_tipo   String            // MIME type
  arquivo_size   Int               // Tamanho em bytes
  data_documento DateTime?         // Data do documento (não do upload)
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @default(now()) @updatedAt

  convenio       Convenio          @relation(fields: [convenioId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@map("convenio_anexos")
}

model ConvenioHistorico {
  id               String                @id @default(uuid())
  convenioId       String
  tenantId         String                // Denormalizado para queries multi-tenant
  tipo             TipoHistoricoConvenio
  titulo           String
  descricao        String                @db.Text
  usuario_nome     String                // Nome de quem registrou
  usuario_id       String                // userId do Sistema 1
  dados_anteriores Json?                 // Snapshot antes da alteração
  dados_novos      Json?                 // Snapshot após a alteração
  createdAt        DateTime              @default(now())

  convenio         Convenio              @relation(fields: [convenioId], references: [id], onDelete: Cascade)

  @@index([tenantId])
  @@index([convenioId, createdAt])
  @@map("convenio_historicos")
}

// ========================================
// REGRAS DE REPASSE
// ========================================

model RegraRepasse {
  id               String                  @id @default(uuid())
  tenantId         String
  profissionalId   String
  convenioId       String?                 // null = aplica a todos os convênios
  procedimentoId   String?                 // null = aplica a todos os procedimentos

  tipo             TipoRepasse
  valor            Decimal                 @db.Decimal(10, 2)
  descricao        String?

  vigencia_inicio  DateTime                @default(now())
  vigencia_fim     DateTime?               // null = sem data fim

  prioridade       Int                     @default(0)    // maior = prevalece em conflito
  ativo            Boolean                 @default(true)
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @default(now()) @updatedAt

  profissional     profissional            @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  convenio         Convenio?               @relation(fields: [convenioId], references: [id], onDelete: SetNull)
  procedimento     Procedimento?           @relation(fields: [procedimentoId], references: [id], onDelete: SetNull)
  historico        RegraRepasseHistorico[]

  @@index([tenantId])
  @@index([profissionalId, ativo])
  @@map("regras_repasse")
}

model RegraRepasseHistorico {
  id               String        @id @default(uuid())
  regraRepasseId   String
  tenantId         String

  tipo_alteracao   String        // CRIACAO, ALTERACAO, DESATIVACAO, REATIVACAO
  descricao        String
  dados_anteriores Json?
  dados_novos      Json?
  usuario_nome     String
  usuario_id       String

  createdAt        DateTime      @default(now())

  regraRepasse     RegraRepasse  @relation(fields: [regraRepasseId], references: [id], onDelete: Cascade)

  @@index([regraRepasseId])
  @@map("regras_repasse_historico")
}

// ========================================
// MÓDULO DE PACOTES DE ATENDIMENTO
// ========================================

model Pacote {
  id               String       @id @default(uuid())
  tenantId         String

  nome             String
  descricao        String?      @db.Text
  tipo             TipoPacote
  status           StatusPacote @default(ATIVO)

  valor_total      Decimal      @db.Decimal(10, 2)
  valor_particular Decimal?     @db.Decimal(10, 2)
  valor_original   Decimal?     @db.Decimal(10, 2)

  total_sessoes    Int?
  validade_dias    Int?
  cor              String?
  icone            String?

  convenioId       String?
  convenio         Convenio?    @relation(fields: [convenioId], references: [id], onDelete: SetNull)

  ativo            Boolean      @default(true)
  observacoes      String?      @db.Text
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @default(now()) @updatedAt

  procedimentos    PacoteProcedimento[]
  historicos       PacoteHistorico[]

  @@index([tenantId])
  @@index([tenantId, status])
  @@map("pacotes")
}

model PacoteProcedimento {
  id             String       @id @default(uuid())
  pacoteId       String
  procedimentoId String
  quantidade     Int          @default(1)
  observacoes    String?

  pacote         Pacote       @relation(fields: [pacoteId], references: [id], onDelete: Cascade)
  procedimento   Procedimento @relation(fields: [procedimentoId], references: [id], onDelete: Restrict)

  @@unique([pacoteId, procedimentoId])
  @@map("pacote_procedimentos")
}

model PacoteHistorico {
  id               String   @id @default(uuid())
  pacoteId         String
  tenantId         String

  tipo_alteracao   String
  descricao        String
  dados_anteriores Json?
  dados_novos      Json?
  usuario_nome     String
  usuario_id       String

  createdAt        DateTime @default(now())

  pacote           Pacote   @relation(fields: [pacoteId], references: [id], onDelete: Cascade)

  @@index([pacoteId])
  @@map("pacotes_historico")
}

// ========================================
// SISTEMA DE AVALIAÇÕES ABA+
// ========================================

model Avaliacao {
  id          String         @id @default(uuid())
  tenantId    String         // Referência ao tenant do Sistema 1 (não FK)
  tipo        TipoAvaliacao
  nome        String
  observacao  String?        @db.Text
  ativo       Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @default(now()) @updatedAt

  niveis      AvaliacaoNivel[]
  habilidades AvaliacaoHabilidade[]
  pontuacoes  AvaliacaoPontuacao[]
  tarefas     AvaliacaoTarefa[]
  atribuicoes PacienteAvaliacao[]
  sessoes     SessaoAvaliacao[]

  @@map("avaliacoes")
}

model AvaliacaoNivel {
  id           String   @id @default(uuid())
  avaliacaoId  String
  ordem        Int
  descricao    String
  faixa_etaria String?  // Ex: "0-2 anos", "3-5 anos"

  avaliacao    Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  tarefas      AvaliacaoTarefa[]

  @@map("avaliacao_niveis")
}

model AvaliacaoHabilidade {
  id           String   @id @default(uuid())
  avaliacaoId  String
  ordem        Int
  habilidade   String

  avaliacao    Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  tarefas      AvaliacaoTarefa[]

  @@map("avaliacao_habilidades")
}

model AvaliacaoPontuacao {
  id           String         @id @default(uuid())
  avaliacaoId  String
  ordem        Int
  tipo         TipoPontuacao
  valor        Int            // Valor numérico (0, 25, 50, 75, 100, -1 para N/A)

  avaliacao    Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)

  @@map("avaliacao_pontuacoes")
}

model AvaliacaoTarefa {
  id                      String   @id @default(uuid())
  avaliacaoId             String
  nivelId                 String?
  habilidadeId            String?
  pergunta                String   @db.Text
  descricao               String?  @db.Text
  criterios_pontuacao     String?  @db.Text
  ordem                   Int?

  avaliacao               Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  nivel                   AvaliacaoNivel? @relation(fields: [nivelId], references: [id], onDelete: SetNull)
  habilidade              AvaliacaoHabilidade? @relation(fields: [habilidadeId], references: [id], onDelete: SetNull)
  respostas               RespostaTarefa[]

  @@map("avaliacao_tarefas")
}

model PacienteAvaliacao {
  id            String   @id @default(uuid())
  pacienteId    String
  avaliacaoId   String
  atribuida_em  DateTime @default(now())
  atribuida_por String   // userId do terapeuta que atribuiu
  ativa         Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @default(now()) @updatedAt

  paciente      paciente  @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  avaliacao     Avaliacao @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)

  @@unique([pacienteId, avaliacaoId])
  @@map("paciente_avaliacoes")
}

model PacienteCurriculum {
  id            String     @id @default(uuid())
  pacienteId    String
  curriculumId  String
  atribuida_em  DateTime   @default(now())
  atribuida_por String     // userId do terapeuta que atribuiu
  ativa         Boolean    @default(true)
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @default(now()) @updatedAt

  paciente        paciente                @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  curriculum      curriculum              @relation(fields: [curriculumId], references: [id], onDelete: Cascade)
  atividadesClone PacienteAtividadeClone[]

  @@unique([pacienteId, curriculumId])
  @@map("paciente_curriculums")
}

model SessaoAvaliacao {
  id                 String          @id @default(uuid())
  pacienteId         String
  avaliacaoId        String
  profissionalId     String
  iniciada_em        DateTime        @default(now())
  finalizada_em      DateTime?
  observacoes_gerais String?         @db.Text
  status             StatusSessao    @default(EM_ANDAMENTO)
  createdAt          DateTime        @default(now())
  updatedAt          DateTime        @default(now()) @updatedAt

  paciente           paciente        @relation(fields: [pacienteId], references: [id], onDelete: Cascade)
  avaliacao          Avaliacao       @relation(fields: [avaliacaoId], references: [id], onDelete: Cascade)
  profissional       profissional    @relation(fields: [profissionalId], references: [id], onDelete: Cascade)
  respostas          RespostaTarefa[]

  @@map("sessao_avaliacoes")
}

model RespostaTarefa {
  id           String           @id @default(uuid())
  sessaoId     String
  tarefaId     String
  pontuacao    Int?             // Valor da pontuação selecionada
  observacao   String?          @db.Text
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @default(now()) @updatedAt

  sessao       SessaoAvaliacao  @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  tarefa       AvaliacaoTarefa  @relation(fields: [tarefaId], references: [id], onDelete: Cascade)

  @@unique([sessaoId, tarefaId])
  @@map("resposta_tarefas")
}

// ========================================
// SISTEMA DE EVOLUÇÃO POR FASES (MÓDULO 20)
// ========================================

model PacienteAtividadeClone {
  id                   String        @id @default(uuid())
  pacienteCurriculumId String
  atividadeOriginalId  String?       // Referência à atividade original (pode ser null se deletada)
  ordem                Int           // Ordem dentro do curriculum do paciente

  // Cópia de todos os campos da atividade
  nome                 String
  protocolo            String?
  habilidade           String?
  marco_codificacao    String?
  tipo_ensino          String?
  qtd_alvos_sessao     Int?
  qtd_tentativas_alvo  Int?

  // Fase atual da atividade para este paciente
  faseAtual            FaseAtividade @default(LINHA_BASE)
  ativo                Boolean       @default(true)

  createdAt            DateTime      @default(now())
  updatedAt            DateTime      @default(now()) @updatedAt

  pacienteCurriculum   PacienteCurriculum          @relation(fields: [pacienteCurriculumId], references: [id], onDelete: Cascade)
  instrucoes           AtividadeCloneInstrucao[]
  pontuacoes           AtividadeClonePontuacao[]
  fases                AtividadeFase[]
  historico            AtividadeFaseHistorico[]
  avaliacoes           AvaliacaoInstrucaoCurriculum[]
  sessoesInstrucao     SessaoCurriculumInstrucao[]

  @@map("paciente_atividade_clones")
}

model AtividadeCloneInstrucao {
  id                    String        @id @default(uuid())
  atividadeCloneId      String
  ordem                 Int
  texto                 String        @db.Text
  como_aplicar          String?       @db.Text
  observacao            String?       @db.Text
  procedimento_correcao String?       @db.Text
  materiais_utilizados  String?       @db.Text

  // Fase individual desta instrução
  faseAtual             FaseAtividade @default(LINHA_BASE)
  ativo                 Boolean       @default(true)
  qtd_tentativas_alvo   Int           @default(1)

  createdAt             DateTime @default(now())
  updatedAt             DateTime @default(now()) @updatedAt

  atividadeClone        PacienteAtividadeClone   @relation(fields: [atividadeCloneId], references: [id], onDelete: Cascade)
  fases                 InstrucaoFase[]
  historico             InstrucaoFaseHistorico[]
  pontuacoes            InstrucaoPontuacao[]
  sessoesInstrucao      SessaoCurriculumInstrucao[]

  @@unique([atividadeCloneId, ordem])
  @@map("atividade_clone_instrucoes")
}

model AtividadeClonePontuacao {
  id               String   @id @default(uuid())
  atividadeCloneId String
  ordem            Int
  sigla            String
  grau             String
  createdAt        DateTime @default(now())
  updatedAt        DateTime @default(now()) @updatedAt

  atividadeClone   PacienteAtividadeClone @relation(fields: [atividadeCloneId], references: [id], onDelete: Cascade)

  @@unique([atividadeCloneId, ordem])
  @@map("atividade_clone_pontuacoes")
}

model AtividadeFase {
  id                       String        @id @default(uuid())
  atividadeCloneId         String
  fase                     FaseAtividade

  // Critérios de Sessão
  porcentagem_acerto       Float         @default(80)
  qtd_sessoes_consecutivas Int           @default(1)

  // Critérios de Avanço/Retrocesso
  fase_se_atingir          FaseAtividade? // Para onde vai se atingir critério (null = concluída/permanecer)
  fase_se_nao_atingir      FaseAtividade? // Para onde vai se não atingir (null = permanecer)

  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @default(now()) @updatedAt

  atividadeClone           PacienteAtividadeClone @relation(fields: [atividadeCloneId], references: [id], onDelete: Cascade)

  @@unique([atividadeCloneId, fase])
  @@map("atividade_fases")
}

model AtividadeFaseHistorico {
  id                  String        @id @default(uuid())
  atividadeCloneId    String
  faseAnterior        FaseAtividade
  faseNova            FaseAtividade
  motivo              String        // "CRITERIO_ATINGIDO" | "CRITERIO_NAO_ATINGIDO" | "ALTERACAO_MANUAL"
  alterado_em         DateTime      @default(now())
  alterado_por        String?       // userId se manual, null se automático
  sessaoCurriculumId  String?       // Sessão que triggou a mudança (null se manual)

  atividadeClone      PacienteAtividadeClone @relation(fields: [atividadeCloneId], references: [id], onDelete: Cascade)

  @@map("atividade_fase_historico")
}

// Critérios de evolução por instrução (granularidade instrução)
model InstrucaoFase {
  id                       String        @id @default(uuid())
  instrucaoId              String
  fase                     FaseAtividade

  porcentagem_acerto       Float         @default(80)
  qtd_sessoes_consecutivas Int           @default(1)

  fase_se_atingir          FaseAtividade?
  fase_se_nao_atingir      FaseAtividade?

  createdAt                DateTime      @default(now())
  updatedAt                DateTime      @default(now()) @updatedAt

  instrucao                AtividadeCloneInstrucao @relation(fields: [instrucaoId], references: [id], onDelete: Cascade)

  @@unique([instrucaoId, fase])
  @@map("instrucao_fases")
}

// Pontuações por instrução por fase
model InstrucaoPontuacao {
  id           String        @id @default(uuid())
  instrucaoId  String
  fase         FaseAtividade
  ordem        Int
  sigla        String
  grau         String
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @default(now()) @updatedAt

  instrucao    AtividadeCloneInstrucao @relation(fields: [instrucaoId], references: [id], onDelete: Cascade)

  @@unique([instrucaoId, fase, ordem])
  @@map("instrucao_pontuacoes")
}

// Histórico de mudanças de fase por instrução
model InstrucaoFaseHistorico {
  id                 String        @id @default(uuid())
  instrucaoId        String
  faseAnterior       FaseAtividade
  faseNova           FaseAtividade
  motivo             String        // "CRITERIO_ATINGIDO" | "CRITERIO_NAO_ATINGIDO" | "ALTERACAO_MANUAL"
  alterado_em        DateTime      @default(now())
  alterado_por       String?
  sessaoCurriculumId String?

  instrucao          AtividadeCloneInstrucao @relation(fields: [instrucaoId], references: [id], onDelete: Cascade)

  @@map("instrucao_fase_historico")
}

// Instruções selecionadas para cada sessão de curriculum
model SessaoCurriculumInstrucao {
  id               String   @id @default(uuid())
  sessaoId         String
  instrucaoId      String
  atividadeCloneId String
  createdAt        DateTime @default(now())

  sessao         SessaoCurriculum        @relation(fields: [sessaoId], references: [id], onDelete: Cascade)
  instrucao      AtividadeCloneInstrucao  @relation(fields: [instrucaoId], references: [id], onDelete: Cascade)
  atividadeClone PacienteAtividadeClone   @relation(fields: [atividadeCloneId], references: [id], onDelete: Cascade)

  @@unique([sessaoId, instrucaoId])
  @@map("sessao_curriculum_instrucoes")
}

// ========================================
// SISTEMA RBAC — MÓDULO 19
// ========================================

model Role {
  id          String          @id @default(uuid())
  tenantId    String          // Isolamento multi-tenant
  nome        String
  descricao   String?         @db.Text
  isSystem    Boolean         @default(false) // true = SUPER_ADMIN, ADMIN, USER (não editáveis)
  ativo       Boolean         @default(true)
  createdAt   DateTime        @default(now())
  updatedAt   DateTime        @default(now()) @updatedAt

  permissoes  RolePermissao[]
  usuarios    UsuarioRole[]

  @@unique([tenantId, nome])
  @@index([tenantId])
  @@map("roles")
}

model Recurso {
  id          String          @id @default(uuid())
  slug        String          @unique // "pacientes", "agenda", "atividades"...
  nome        String          // "Pacientes", "Agenda", "Atividades"...
  modulo      String?         // Agrupamento visual (ex: "Clínico", "Administrativo")
  ordem       Int             @default(0)
  ativo       Boolean         @default(true)

  permissoes  RolePermissao[]

  @@map("recursos")
}

model Acao {
  id          String          @id @default(uuid())
  slug        String          @unique // "VIEW", "CREATE", "UPDATE", "DELETE", "EXPORT", "APPROVE", "MANAGE"
  nome        String          // "Visualizar", "Criar", "Editar", "Deletar", "Exportar", "Aprovar", "Gerenciar"
  ordem       Int             @default(0)

  permissoes  RolePermissao[]

  @@map("acoes")
}

model RolePermissao {
  id          String   @id @default(uuid())
  roleId      String
  recursoId   String
  acaoId      String
  createdAt   DateTime @default(now())

  role        Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  recurso     Recurso  @relation(fields: [recursoId], references: [id], onDelete: Cascade)
  acao        Acao     @relation(fields: [acaoId], references: [id], onDelete: Cascade)

  @@unique([roleId, recursoId, acaoId])
  @@index([roleId])
  @@map("role_permissoes")
}

model UsuarioRole {
  id             String   @id @default(uuid())
  usuarioId      String   // ID do usuário no Sistema 1 (SSO)
  tenantId       String   // Isolamento multi-tenant
  roleId         String
  atribuido_por  String   // userId de quem atribuiu
  justificativa  String?  @db.Text
  ativo          Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @default(now()) @updatedAt

  role           Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([usuarioId, tenantId]) // Um usuário tem uma role por tenant
  @@index([tenantId])
  @@map("usuario_roles")
}

model UsuarioRoleHistorico {
  id             String   @id @default(uuid())
  usuarioId      String   // ID do usuário no Sistema 1
  tenantId       String
  roleAnteriorId String?  // null = primeira atribuição
  roleNovoId     String?  // null = remoção
  acao           String   // "ATRIBUICAO" | "ALTERACAO" | "REMOCAO"
  alterado_por   String   // userId de quem fez a alteração
  justificativa  String?  @db.Text
  createdAt      DateTime @default(now())

  @@index([usuarioId, tenantId])
  @@index([tenantId])
  @@map("usuario_role_historico")
}
